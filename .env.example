# Server
PORT=8080
HOST=0.0.0.0

# Public base URL (used for generating download links, e.g. https://yourdomain.com)
APP_BASE_URL=

# yt-dlp binary path (default: yt-dlp in PATH)
YTDLP_BIN=yt-dlp

# ffmpeg binary path (default: ffmpeg in PATH)
FFMPEG_BIN=ffmpeg

# Path to a Netscape cookies file for yt-dlp (default: secrets/youtube-cookies.txt)
YTDLP_COOKIES_FILE=

# Extract cookies from a browser profile (e.g. chrome, firefox)
YTDLP_COOKIES_FROM_BROWSER=

# Maximum number of simultaneous downloads
MAX_CONCURRENT_DOWNLOADS=2

# Maximum allowed URL length in characters
MAX_URL_LENGTH=2048

# How many hours to retain completed downloads before cleanup
DOWNLOADS_RETENTION_HOURS=24

# Cloudflare R2 storage (optional — leave blank to use local disk)
R2_ACCOUNT_ID=
R2_BUCKET=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_REGION=auto
R2_PUBLIC_BASE_URL=
