[Unit]
Description=YouTube Downloader
After=network.target

[Service]
Type=simple
User=ytdl
Group=ytdl
WorkingDirectory=/opt/youtube-downloader
ExecStart=/usr/bin/node server/index.js
Restart=on-failure
RestartSec=5

# Environment
EnvironmentFile=/opt/youtube-downloader/.env

# Security hardening
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ReadWritePaths=/opt/youtube-downloader/data /opt/youtube-downloader/secrets

[Install]
WantedBy=multi-user.target
